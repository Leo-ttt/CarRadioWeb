{
  "name": "knowledge-base",
  "version": "1.0.0",
  "description": "现代化知识库管理系统",
  "type": "module",
  "scripts": {
    "dev": "npx vite",
    "dev:backend": "cd backend && npm run dev",
    "dev:all": "concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"wait-on http://localhost:3000 -t 60000 && npm run dev\"",
    "dev:debug": "npx vite --debug",
    "dev:host": "npx vite --host",
    "build": "cd backend && tsc && cd .. && npx vite build",
    "build:analyze": "npm run build && npx vite-bundle-analyzer dist/assets/*.js",
    "preview": "npx vite preview",
    "preview:host": "npx vite preview --host",
    "lint": "npx eslint .",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css,md}\"",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist node_modules/.vite",
    "test:build": "npm run type-check && npm run lint && npm run test:run && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/d3": "^7.4.3",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^24.3.0",
    "@types/topojson-client": "^3.1.5",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^5.0.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vite": "^7.3.0",
    "wait-on": "^8.0.5"
  },
  "dependencies": {
    "@lottiefiles/dotlottie-react": "^0.17.10",
    "@sentry/react": "^8.40.0",
    "@swc/helpers": "^0.5.19",
    "@tanstack/react-query": "^5.60.0",
    "@tanstack/react-table": "^8.21.3",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "dompurify": "^3.2.6",
    "embla-carousel-autoplay": "^8.3.1",
    "embla-carousel-react": "^8.3.1",
    "framer-motion": "^11.12.0",
    "i18next": "^25.4.1",
    "i18next-browser-languagedetector": "^8.2.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.541.0",
    "primeicons": "^7.0.0",
    "primereact": "^10.9.7",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-error-boundary": "^6.0.0",
    "react-i18next": "^15.7.2",
    "react-intersection-observer": "^9.13.1",
    "react-pdf": "^10.3.0",
    "react-router-dom": "^7.8.2",
    "react-toggle-dark-mode": "^2.0.0",
    "recharts": "^2.12.7",
    "tailwind-merge": "^3.3.1",
    "topojson-client": "^3.1.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  }
}
