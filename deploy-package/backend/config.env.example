# 阿里云OSS配置
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_BUCKET=your_bucket_name
OSS_REGION=oss-cn-hangzhou
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# OSS路径前缀（可选）
# 留空则直接存储到桶根目录，设置后会在所有文件路径前添加此前缀
# 例如：OSS_PATH_PREFIX=knowledge-base/ 或 OSS_PATH_PREFIX=uploads/
# 默认值：knowledge-base/
OSS_PATH_PREFIX=knowledge-base/

# 服务器配置
PORT=3001
NODE_ENV=development

# 数据库配置
MONGODB_URI=mongodb://localhost:27017/official-website

# JWT配置
JWT_SECRET=your_jwt_secret_key_here

# CORS配置 - 支持多个前端域名
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,https://yourdomain.com

# OpenAI配置
OPENAI_API_KEY=your_openai_api_key

# 清理任务配置
CLEANUP_ENABLED=true
TEMP_FILE_RETENTION_DAYS=7
DELETED_RECORD_RETENTION_DAYS=30
